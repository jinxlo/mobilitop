generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
  DISCARDED
}

enum AvailabilityStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  ON_REQUEST
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(ADMIN)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model SiteSettings {
  id             String   @id @default(cuid())
  businessName   String   @map("business_name")
  businessDescription String? @map("business_description")
  logoUrl        String?  @map("logo_url")
  faviconUrl     String?  @map("favicon_url")
  primaryColor   String   @default("#1E3A5F") @map("primary_color")
  secondaryColor String   @default("#F5EFE6") @map("secondary_color")
  accentColor    String   @default("#C9A24A") @map("accent_color")
  whatsappNumber String   @map("whatsapp_number")
  phoneNumber    String?  @map("phone_number")
  email          String?
  instagramUrl   String?  @map("instagram_url")
  facebookUrl    String?  @map("facebook_url")
  tiktokUrl      String?  @map("tiktok_url")
  address        String?
  googleMapsUrl  String?  @map("google_maps_url")
  openingHours   String?  @map("opening_hours")
  defaultCurrency String  @default("USD") @map("default_currency")
  heroTitle      String   @default("Encuentra el colchón ideal para tu descanso") @map("hero_title")
  heroSubtitle   String   @default("Asesoría personalizada, variedad de medidas y atención directa por WhatsApp.") @map("hero_subtitle")
  whatsappDefaultMessage String @default("Hola, estoy viendo su página web y necesito más información.") @map("whatsapp_default_message")
  deliveryInfo   String?  @map("delivery_info")
  warrantyInfo   String?  @map("warranty_info")
  paymentMethods String[] @default([]) @map("payment_methods")
  policies       String?
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?   @map("image_url")
  icon        String?
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@map("categories")
}

model Brand {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logoUrl     String?   @map("logo_url")
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]

  @@map("brands")
}

model Product {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  sku                String?
  brandId            String?            @map("brand_id")
  categoryId         String             @map("category_id")
  subcategory        String?
  mattressSize       String?            @map("mattress_size")
  mattressType       String?            @map("mattress_type")
  firmness           String?
  price              Decimal            @db.Decimal(12, 2)
  previousPrice      Decimal?           @map("previous_price") @db.Decimal(12, 2)
  currency           String             @default("USD")
  stockQuantity      Int                @default(0) @map("stock_quantity")
  availabilityStatus AvailabilityStatus @default(IN_STOCK) @map("availability_status")
  shortDescription   String?            @map("short_description")
  longDescription    String?            @map("long_description")
  features           String[]           @default([])
  materials          String[]           @default([])
  warranty           String?
  careInstructions   String?            @map("care_instructions")
  searchableContent  String?            @map("searchable_content")
  seoTitle           String?            @map("seo_title")
  seoDescription     String?            @map("seo_description")
  isActive           Boolean            @default(true) @map("is_active")
  isFeatured         Boolean            @default(false) @map("is_featured")
  isPromotion        Boolean            @default(false) @map("is_promotion")
  sortOrder          Int                @default(0) @map("sort_order")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  brand              Brand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category           Category           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images             ProductImage[]
  leads              Lead[]

  @@index([categoryId])
  @@index([brandId])
  @@index([price])
  @@index([isActive, isFeatured, isPromotion])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  imageUrl  String   @map("image_url")
  altText   String?  @map("alt_text")
  sortOrder Int      @default(0) @map("sort_order")
  isMain    Boolean  @default(false) @map("is_main")
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Lead {
  id            String     @id @default(cuid())
  name          String
  phone         String
  email         String?
  message       String
  productId     String?    @map("product_id")
  source        String?
  status        LeadStatus @default(NEW)
  internalNotes String?    @map("internal_notes")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  product       Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("leads")
}

model HeroSlide {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String   @map("image_url")
  buttonLabel String?  @map("button_label")
  buttonUrl   String?  @map("button_url")
  secondaryButtonLabel String? @map("secondary_button_label")
  secondaryButtonUrl   String? @map("secondary_button_url")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("hero_slides")
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}
